# VibeForge Environment Example
# Copy to .env.local and fill actual values.
# Never commit .env.local.

NEXT_PUBLIC_APP_NAME=VibeForge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NocoDB
NOCODB_BASE_URL=https://app.nocodb.com
NOCODB_WORKSPACE_ID=your_workspace_id
NOCODB_BASE_ID=your_base_id
NOCODB_API_TOKEN=your_nocodb_api_token

# AI Providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Optional Providers
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=
ZEN_BASE_URL=
OPENCODE_BASE_URL=

# Workspace Runtime
VIBEFORGE_WORKSPACE_ROOT=
VIBEFORGE_ENABLE_TERMINAL=true
VIBEFORGE_ENABLE_GIT=true
VIBEFORGE_ENABLE_LOCAL_BRIDGE=false
